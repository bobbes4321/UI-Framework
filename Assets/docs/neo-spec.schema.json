{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Neo UI Spec",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "theme": {
      "type": "object",
      "properties": {
        "bundle": {
          "enum": [
            "CleanSlate",
            "NeonArcade",
            "SoftFantasy"
          ]
        },
        "tokens": {
          "type": "object"
        },
        "variants": {
          "type": "object"
        }
      }
    },
    "views": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/view"
      }
    },
    "popups": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/popup"
      }
    },
    "presets": {
      "type": "array"
    },
    "flow": {
      "type": "object"
    }
  },
  "definitions": {
    "view": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "\"Category/Name\""
        },
        "showAnimation": {
          "type": "string"
        },
        "hideAnimation": {
          "type": "string"
        },
        "background": {
          "type": "string",
          "description": "theme token"
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/element"
          }
        }
      }
    },
    "popup": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "size": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "close": {
          "type": "boolean",
          "description": "X dismiss button on the card corner"
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/element"
          }
        }
      }
    },
    "element": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": false,
      "properties": {
        "button": {
          "$ref": "#/definitions/elementBody"
        },
        "toggle": {
          "$ref": "#/definitions/elementBody"
        },
        "switch": {
          "$ref": "#/definitions/elementBody"
        },
        "tab": {
          "$ref": "#/definitions/elementBody"
        },
        "slider": {
          "$ref": "#/definitions/elementBody"
        },
        "progress": {
          "$ref": "#/definitions/elementBody"
        },
        "tabbar": {
          "$ref": "#/definitions/elementBody"
        },
        "list": {
          "$ref": "#/definitions/elementBody"
        },
        "scroll": {
          "$ref": "#/definitions/elementBody"
        },
        "vstack": {
          "$ref": "#/definitions/elementBody"
        },
        "hstack": {
          "$ref": "#/definitions/elementBody"
        },
        "grid": {
          "$ref": "#/definitions/elementBody"
        },
        "panel": {
          "$ref": "#/definitions/elementBody"
        },
        "overlay": {
          "$ref": "#/definitions/elementBody"
        },
        "spacer": {
          "$ref": "#/definitions/elementBody"
        },
        "text": {
          "$ref": "#/definitions/elementBody"
        },
        "image": {
          "$ref": "#/definitions/elementBody"
        },
        "shape": {
          "$ref": "#/definitions/elementBody"
        },
        "icon": {
          "$ref": "#/definitions/elementBody"
        },
        "input": {
          "$ref": "#/definitions/elementBody"
        },
        "stepper": {
          "$ref": "#/definitions/elementBody"
        },
        "safearea": {
          "$ref": "#/definitions/elementBody"
        },
        "counter": {
          "$ref": "#/definitions/elementBody"
        },
        "dropdown": {
          "$ref": "#/definitions/elementBody"
        },
        "settings": {
          "$ref": "#/definitions/elementBody"
        },
        "cheats": {
          "$ref": "#/definitions/elementBody"
        }
      }
    },
    "elementBody": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "description": "\"Category/Name\""
        },
        "label": {
          "type": "string"
        },
        "color": {
          "type": "string",
          "description": "theme token or #hex"
        },
        "labelColor": {
          "type": "string",
          "description": "theme token"
        },
        "background": {
          "type": "string",
          "description": "theme token or #hex"
        },
        "controls": {
          "type": "string",
          "description": "tab: id of the sibling panel it shows/hides"
        },
        "src": {
          "type": "string",
          "description": "image: sprite asset path (\"Assets/...\"); radius rounds the corners"
        },
        "bind": {
          "type": "string",
          "description": "list/grid: UIData source id feeding rows at runtime"
        },
        "item": {
          "$ref": "#/definitions/element"
        },
        "align": {
          "enum": [
            "left",
            "center",
            "right"
          ]
        },
        "anchor": {
          "enum": [
            "TopLeft",
            "Top",
            "TopRight",
            "Left",
            "Center",
            "Right",
            "BottomLeft",
            "Bottom",
            "BottomRight",
            "Stretch",
            "StretchTop",
            "StretchBottom",
            "StretchLeft",
            "StretchRight",
            "StretchHorizontal",
            "StretchVertical"
