{
  "theme": { "bundle": "CleanSlate" },
  "views": [
    {
      "id": "Showcase/Popups",
      "background": "Background",
      "elements": [
        {
          "safearea": {
            "children": [
              {
                "vstack": {
                  "anchor": "Center",
                  "size": [520, 360],
                  "spacing": 16,
                  "children": [
                    {
                      "text": {
                        "label": "Popups",
                        "color": "TextStrong",
                        "textStyle": "Title"
                      }
                    },
                    {
                      "text": {
                        "label": "A plain confirm card and a rich popup with custom content.",
                        "color": "TextMuted",
                        "textStyle": "Caption"
                      }
                    },
                    {
                      "button": {
                        "id": "Popups/OpenPlain",
                        "label": "Open confirm",
                        "icon": "circle-help",
                        "variant": "primary",
                        "onClick": { "popup": "ConfirmDelete" }
                      }
                    },
                    {
                      "button": {
                        "id": "Popups/OpenRich",
                        "label": "Open reward",
                        "icon": "gift",
                        "variant": "secondary",
                        "onClick": { "popup": "RewardClaim" }
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  ],
  "popups": [
    {
      "name": "ConfirmDelete",
      "title": "Delete save?",
      "message": "This permanently removes your progress. This cannot be undone."
    },
    {
      "name": "RewardClaim",
      "size": [560, 460],
      "close": true,
      "elements": [
        {
          "vstack": {
            "anchor": "Stretch",
            "padding": 32,
            "spacing": 16,
            "children": [
              {
                "icon": {
                  "name": "trophy",
                  "color": "Primary",
                  "size": [72, 72],
                  "particles": {
                    "capacity": 36, "rate": 10, "emitOnEnable": true,
                    "particleShape": "Circle",
                    "sizeRange": [3, 7], "lifetimeRange": [0.8, 1.6], "speedRange": [25, 70],
                    "emitAngle": 90, "emitSpread": 360, "angularVelocityRange": [-40, 40],
                    "modules": [
                      { "id": "drag", "params": { "drag": 0.6 } },
                      { "id": "colorOverLife", "params": { "start": "Warning", "end": "#FFE08A00", "ease": "OutQuad" } },
                      { "id": "sizeOverLife", "params": { "startScale": 1.0, "endScale": 0.0, "ease": "OutQuad" } }
                    ]
                  }
                }
              },
              {
                "text": {
                  "label": "Daily Reward",
                  "color": "TextStrong",
                  "textStyle": "Heading"
                }
              },
              {
                "text": {
                  "label": "You earned 500 coins for logging in today.",
                  "color": "TextMuted",
                  "textStyle": "Body"
                }
              },
              {
                "hstack": {
                  "spacing": 8,
                  "align": "center",
                  "children": [
                    { "icon": { "name": "coins", "color": "Primary", "size": [36, 36] } },
                    {
                      "counter": {
                        "label": "#,0",
                        "size": [160, 48],
                        "value": 500,
                        "textStyle": "Title"
                      }
                    }
                  ]
                }
              },
              {
                "button": {
                  "id": "RewardClaim/Claim",
                  "label": "CLAIM",
                  "icon": "check",
                  "variant": "primary",
                  "onClick": { "close": true, "signal": { "category": "Reward", "name": "Claimed" } },
                  "particles": {
                    "capacity": 64, "burstCount": 36, "rate": 0,
                    "particleShape": "Circle",
                    "sizeRange": [7, 14], "lifetimeRange": [0.7, 1.3], "speedRange": [300, 580],
                    "emitAngle": 90, "emitSpread": 70, "angularVelocityRange": [-220, 220],
                    "modules": [
                      { "id": "gravity", "params": { "acceleration": [0, -1000] } },
                      { "id": "drag", "params": { "drag": 0.25 } },
                      { "id": "colorOverLife", "params": { "start": "Warning", "end": "#FFE08A00", "ease": "InQuad" } },
                      { "id": "sizeOverLife", "params": { "startScale": 1.0, "endScale": 0.4, "ease": "OutQuad" } }
                    ],
                    "signal": { "category": "Reward", "name": "Claimed", "count": 36 }
                  }
                }
              }
            ]
          }
        }
      ]
    }
  ]
}
