  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Glow / Sheen / Gradient Cycle / Arc Spinner / Corner Morph / Border Pulse
    / Hue Shift / Transform Juice are Tier-1: they only animate fields the shared
    SDF shader already reads (or the RectTransform), so every card still batches
    into one draw call. Dissolve / Holo Foil / Glitch are Tier-2 \u2014 each its
    own fragment shader on a per-variant material, a deliberate batch split the cost-lint
    flags. The Interactive tab adds pointer triggers (hover/press), click-positioned
    particles and a cursor-follow glow \u2014 try them in Play mode. Run Tools \u2192
    Neo UI \u2192 Setup \u2192 Create or Repair Effect Assets once to bake the Tier-2
    materials."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2fa276f5f181d5e4f8aee3a61c798e0d, type: 2}
