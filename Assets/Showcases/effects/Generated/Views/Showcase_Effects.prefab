  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Glow / Sheen / Gradient Cycle are Tier-1: they only animate fields the
    shared SDF shader already reads (edge softness, gradient stops/angle), so every
    card still batches into one draw call. Dissolve is Tier-2 \u2014 its own fragment
    shader on a per-variant material, a deliberate batch split the cost-lint flags.
    Run Tools \u2192 Neo UI \u2192 Setup \u2192 Create or Repair Effect Assets once
    to bake the dissolve material."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2fa276f5f181d5e4f8aee3a61c798e0d, type: 2}
